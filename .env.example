# Intuit Production credentials — paste from developer.intuit.com → your app → Keys & credentials → Production
QB_CLIENT_ID=
QB_CLIENT_SECRET=

# OAuth redirect URI (must match what's registered in Intuit Developer)
QB_REDIRECT_URI=http://localhost:3000/callback

# 'production' or 'sandbox'
QB_ENVIRONMENT=production

# Your QuickBooks company Realm ID (gear icon in QBO → Additional info → Company ID)
QB_REALM_ID=

# Local server port
PORT=3000

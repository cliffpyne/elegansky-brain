{
  "name": "elegansky-brain",
  "version": "0.1.0",
  "description": "EleganskyBrain — QuickBooks master integration layer",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "web:install": "npm --prefix web install",
    "web:build": "npm --prefix web run build",
    "build": "npm run web:install && npm run web:build",
    "postinstall": "npm run web:install || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "googleapis": "^172.0.0",
    "intuit-oauth": "^4.2.0",
    "jose": "^6.2.3",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=20"
  }
}
